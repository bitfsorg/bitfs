# BitFS local E2E environment template
# Keep all networks in one .env; switch with BITFS_E2E_NETWORK.
# Do NOT commit .env.

# Active network: regtest | testnet | mainnet
BITFS_E2E_NETWORK=mainnet
BITFS_E2E_PROVIDER=arc

# Network-specific ARC endpoints (suffix: _MAINNET / _TESTNET / _REGTEST)
BITFS_E2E_ARC_BASE_URL_TESTNET=https://testnet.arc.gorillapool.io/v1
BITFS_E2E_ARC_BASE_URL_MAINNET=https://arc.taal.com/v1
BITFS_E2E_ARC_BASE_URLS_MAINNET=https://arc.taal.com/v1,https://arc.gorillapool.io/v1

# Network-specific API keys
BITFS_E2E_ARC_API_KEY_TESTNET=
BITFS_E2E_ARC_API_KEY_MAINNET=
BITFS_E2E_WOC_API_KEY_TESTNET=
BITFS_E2E_WOC_API_KEY_MAINNET=

# Network-specific funding WIF (required on live networks)
BITFS_E2E_FUND_WIF_TESTNET=
BITFS_E2E_FUND_WIF_MAINNET=

# Keep funding conservative for BSV tests
BITFS_E2E_FUND_AMOUNT_TESTNET=0.00006
BITFS_E2E_FUND_AMOUNT_MAINNET=0.00006

# Optional timeout overrides
# BITFS_E2E_CONFIRM_TIMEOUT_TESTNET=30m
# BITFS_E2E_CONFIRM_TIMEOUT_MAINNET=60m

# Optional shared fallback (used only when network-specific key is not set)
# BITFS_E2E_ARC_API_KEY=
# BITFS_E2E_WOC_API_KEY=
# BITFS_E2E_FUND_WIF=
