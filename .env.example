# BitFS local E2E environment template
# Copy to .env and fill real values. Do NOT commit .env.

# Network: regtest | testnet | mainnet
BITFS_E2E_NETWORK=testnet
BITFS_E2E_PROVIDER=arc

# ARC endpoints
BITFS_E2E_ARC_BASE_URL=https://testnet.arc.gorillapool.io/v1
# For mainnet failover, use comma-separated list, e.g.:
# BITFS_E2E_ARC_BASE_URLS=https://arc.taal.com/v1,https://arc.gorillapool.io/v1
BITFS_E2E_ARC_API_KEY=

# Whatsonchain (optional but recommended to reduce rate limits)
BITFS_E2E_WOC_API_KEY=

# Funding wallet WIF (required on live networks)
BITFS_E2E_FUND_WIF=

# Keep funding conservative for BSV tests
BITFS_E2E_FUND_AMOUNT=0.00006

# Optional timeout override
# BITFS_E2E_CONFIRM_TIMEOUT=30m
